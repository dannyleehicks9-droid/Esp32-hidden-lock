#include <BLEDevice.h>
#include <BLEUtils.h>
#include <BLEScan.h>
#include <BLEAdvertisedDevice.h>

int scanTime = 5; // Scan the room every 5 seconds
BLEScan* pBLEScan;

class MyAdvertisedDeviceCallbacks: public BLEAdvertisedDeviceCallbacks {
    void onResult(BLEAdvertisedDevice advertisedDevice) {
        // Print the hardware MAC address
        Serial.print("MAC Address: ");
        Serial.print(advertisedDevice.getAddress().toString().c_str());
        
        // Print the Signal Strength (RSSI)
        Serial.print(" | Signal (RSSI): ");
        Serial.print(advertisedDevice.getRSSI());
        
        // Print the device name if it broadcasts one
        if (advertisedDevice.haveName()) {
            Serial.print(" | Name: ");
            Serial.print(advertisedDevice.getName().c_str());
        }
        
        Serial.println();
    }
};

void setup() {
  Serial.begin(115200);
  Serial.println("Starting Bluetooth Sniffer... Hold your key fob/phone close!");

  BLEDevice::init("");
  pBLEScan = BLEDevice::getScan(); // Create new scan
  pBLEScan->setAdvertisedDeviceCallbacks(new MyAdvertisedDeviceCallbacks());
  pBLEScan->setActiveScan(true); // Active scan uses more power but gets names quicker
  pBLEScan->setInterval(100);
  pBLEScan->setWindow(99);  
}

void loop() {
  Serial.println("\n--- STARTING NEW SCAN CYCLE ---");
  BLEScanResults* foundDevices = pBLEScan->start(scanTime, false);
  pBLEScan->clearResults();   // Clear memory buffer
  delay(1000);
}
